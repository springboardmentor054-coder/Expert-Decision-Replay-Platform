# Copy this file to .env and adjust values

# For local/dev testing, SQLite is used automatically if DATABASE_URL is left blank.
# For production, point to PostgreSQL, e.g.:
# DATABASE_URL=postgresql+psycopg2://edrp_user:edrp_pass@localhost:5432/edrp_db
DATABASE_URL=

# JWT settings
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# File storage
UPLOAD_DIR=app/uploads
MAX_UPLOAD_MB=20

# First admin bootstrap (optional convenience for first run)
FIRST_ADMIN_EMAIL=admin@edrp.local
FIRST_ADMIN_PASSWORD=Admin@12345
